# ──────────────────────────────────────────────────────────────────────────────
# SearXNG AI Overview Plugin — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and customize as needed.
# All values shown are the defaults — you only need to set what you want to change.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ollama Connection ────────────────────────────────────────────────────────

# URL of your Ollama instance.
# If running Ollama on the host and SearXNG in Docker, use host.docker.internal.
OLLAMA_URL=http://host.docker.internal:11434

# The LLM used for generating AI overviews.
# Recommended: llama3.2 (good balance of speed and quality)
# Alternatives: llama3.2, mistral, gemma3:4b
OLLAMA_CHAT_MODEL=llama3.2

# The embedding model used for semantic re-ranking of search results.
# Only used when AI_RERANKING is enabled.
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Generation Settings ─────────────────────────────────────────────────────

# Maximum number of tokens in the AI response (100–8192).
AI_MAX_TOKENS=2048

# LLM temperature (0.0–2.0). Lower = more focused, higher = more creative.
AI_TEMPERATURE=0.2

# ── Context Window ──────────────────────────────────────────────────────────

# Number of top search results to include with full text snippets (0–20).
# These give the AI detailed information to work with.
AI_CONTEXT_DEEP=5

# Number of additional results to include as headlines only (0–30).
# These give the AI broader awareness of available sources.
AI_CONTEXT_SHALLOW=10

# ── Behavior ────────────────────────────────────────────────────────────────

# Comma-separated list of SearXNG tabs where AI Overview is active.
AI_TABS=general,science,it,news

# Requests per minute per IP address (1–120).
AI_RATE_LIMIT=10

# Enable semantic re-ranking of search results using embeddings.
# Requires the embedding model (nomic-embed-text) to be pulled in Ollama.
# Set to false to save resources or if the embedding model is unavailable.
AI_RERANKING=false

# Enable interactive features (follow-up questions, copy, regenerate).
AI_INTERACTIVE=true

# Only trigger AI overview for queries containing a question mark.
# Useful to reduce unnecessary AI calls.
AI_QUESTION_MARK_ONLY=false
